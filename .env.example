# Cloudflare Workers API endpoint
VITE_WORKERS_API_URL=https://your-worker.workers.dev

# Supabase project config (Dashboard → Settings → API)
# The anon key is safe to expose publicly ONLY if Row Level Security is enabled.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
