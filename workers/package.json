{
  "name": "lifepath-workers",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create lifepath",
    "db:init": "wrangler d1 execute lifepath --file=./schema.sql",
    "db:migrate": "wrangler d1 migrations apply lifepath"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "wrangler": "^4.95.0"
  }
}
